# ==================================================
# ESPHome SINOTIMER Project - .gitignore
# ==================================================

# -------------------- Секреты и пароли --------------------
secrets.yaml
*secrets.yaml
!example.secrets.yaml

# -------------------- Скомпилированные файлы ESPHome --------------------
# Собранные прошивки
*.bin
*.bin.gz
*.hex
*.elf
*.map

# Сборки ESPHome (папка .esphome)
.esphome/
build/
dist/

# -------------------- Логи и отладочные файлы --------------------
*.log
*.log.*
logs/
debug.log
debug_*.txt

# -------------------- Временные файлы --------------------
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.orig
*.rej

# -------------------- Файлы зависимостей --------------------
# ESPHome внешние компоненты (если используете)
esphome-components/
custom_components/
!custom_components/README.md

# -------------------- IDE и редакторы --------------------
# VSCode
.vscode/
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# -------------------- Python специфичные файлы --------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/

# -------------------- Документация и временные сборки --------------------
# Сгенерированная документация
docs/_build/
site/

# Экспортированные конфиги
exported_configs/
backup_*.yaml

# -------------------- Файлы с реальными данными --------------------
# Если вы сохраняли дампы Tuya
tuya_dump*.txt
dp_dump*.json

# Логи с реальными MAC адресами
wifi_scan*.txt
mac_list*.txt

# -------------------- Образы для прошивки --------------------
# Файлы для ESPHome Flasher
*.flasher.json
flash_*.bat
flash_*.sh

# -------------------- Пользовательские настройки --------------------
# Локальные оверрайды
local_overrides.yaml
user_overrides.yaml
*.local.yaml

# -------------------- Но НЕ игнорируем --------------------
# Важно: сохраняем примеры и шаблоны
!example.secrets.yaml
!*.example.yaml
!README.md
!LICENSE
!.github/
!docs/README.md
